## 总结
print("\n=== 测试总结 ===")
print("所有基础功能测试完成！")

# 使用测试框架运行正式测试
suite "Complete Test Suite" {
    test "variable types" {
        let a = 1
        let b = "str"
        let c = true
        assert type(a) == "int"
        assert type(b) == "str"
        assert type(c) == "bool"
    }
    
    test "list operations" {
        let lst = [1, 2, 3]
        assert len(lst) == 3
        assert lst[0] == 1
    }
    
    test "dict operations" {
        let d = { "key": "value" }
        assert d["key"] == "value"
    }
    
    test "function call" {
        function double(x) { return x * 2 }
        assert double(5) == 10
    }
    
    test "keyword arguments" {
        function greet(n, g="Hi") { return g + ", " + n }
        assert greet("Alice") == "Hi, Alice"
        assert greet("Bob", g="Hello") == "Hello, Bob"
    }
}

test.run("Complete Test Suite")
print("\n=== 所有测试通过！===")
