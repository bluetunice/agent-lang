# 完整功能测试套件 - AFL v1.3

print("=== AFL 完整功能测试开始 ===")

## 1. 基础变量与类型测试
print("\n=== 1. 基础变量与类型 ===")

let name = "Alice"
let count = 10
let rate = 3.14
let active = true
let items = [1, 2, 3, 4, 5]
let config = { "timeout": 30, "retry": true, "mode": "auto" }
let empty = null

assert name == "Alice"
assert count == 10
assert rate == 3.14
assert active == true
assert len(items) == 5
assert config["timeout"] == 30
assert config["retry"] == true
assert empty == null

print("基础变量测试通过")

## 2. 类型检查
print("\n=== 2. 类型检查 ===")

assert type(name) == "str"
assert type(count) == "int"
assert type(rate) == "float"
assert type(active) == "bool"
assert type(items) == "list"
assert type(config) == "dict"
assert type(empty) == "NoneType"

print("类型检查测试通过")

## 3. 运算符测试
print("\n=== 3. 运算符测试 ===")

# 算术运算
assert 10 + 5 == 15
assert 10 - 5 == 5
assert 10 * 5 == 50
assert 10 / 5 == 2.0
assert 10 ** 2 == 100
assert 10 % 3 == 1

# 比较运算
assert 10 > 5
assert 10 >= 10
assert 5 < 10
assert 5 <= 5
assert 10 == 10
assert 10 != 5

# 逻辑运算
assert true and true
assert true or false
assert not false

# 字符串拼接
assert "Hello" + " " + "World" == "Hello World"

print("运算符测试通过")

## 4. 索引访问测试
print("\n=== 4. 索引访问测试 ===")

let list_data = [10, 20, 30, 40, 50]
let dict_data = { "a": 100, "b": 200, "c": 300 }

assert list_data[0] == 10
assert list_data[2] == 30
assert list_data[4] == 50
assert dict_data["a"] == 100
assert dict_data["b"] == 200
assert dict_data["c"] == 300

# 字符串索引
let str_data = "Hello"
assert str_data[0] == "H"
assert str_data[4] == "o"

print("索引访问测试通过")

## 5. 条件分支测试
print("\n=== 5. 条件分支测试 ===")

let score = 85

if score >= 90 {
    let grade = "A"
    assert grade == "A"
} else if score >= 80 {
    let grade = "B"
    assert grade == "B"
} else {
    let grade = "C"
    assert false  # 不应该到这里
}

# 三元表达式
let result = if score >= 60 then "pass" else "fail"
assert result == "pass"

let result2 = if score >= 90 then "excellent" else "good"
assert result2 == "good"

print("条件分支测试通过")

## 6. 循环测试
print("\n=== 6. 循环测试 ===")

# for-in 循环（range）
let sum1 = 0
for i in range(5) {
    sum1 = sum1 + i
}
assert sum1 == 0 + 1 + 2 + 3 + 4

# for-in 循环（列表）
let sum2 = 0
for item in [10, 20, 30] {
    sum2 = sum2 + item
}
assert sum2 == 60

# while 循环
let counter = 0
let sum3 = 0
while counter < 5 {
    sum3 = sum3 + counter
    counter = counter + 1
}
assert sum3 == 0 + 1 + 2 + 3 + 4
assert counter == 5

# break 测试
let break_sum = 0
for i in range(10) {
    if i >= 3 {
        break
    }
    break_sum = break_sum + i
}
assert break_sum == 0 + 1 + 2
assert i == 3  # 注意：i 在循环外可能不可访问，这取决于实现

print("循环测试通过")

## 7. 函数测试
print("\n=== 7. 函数测试 ===")

function add(a, b) {
    return a + b
}

function multiply(a, b) {
    return a * b
}

function greet(name) -> string {
    return "Hello, " + name + "!"
}

function factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

function with_default(name, greeting="Hello") -> string {
    return greeting + ", " + name + "!"
}

assert add(3, 5) == 8
assert multiply(4, 6) == 24
assert greet("World") == "Hello, World!"
assert factorial(5) == 120
assert with_default("Alice") == "Hello, Alice!"
assert with_default("Bob", greeting="Hi") == "Hi, Bob!"

print("函数测试通过")

## 8. 列表操作测试
print("\n=== 8. 列表操作 ===")

let lst = [1, 2, 3]
append(lst, 4)
assert len(lst) == 4
assert lst[3] == 4

let popped = pop(lst)
assert popped == 4
assert len(lst) == 3

let sorted_lst = sort([3, 1, 4, 1, 5])
assert sorted_lst[0] == 1
assert sorted_lst[1] == 1
assert sorted_lst[2] == 3
assert sorted_lst[3] == 4
assert sorted_lst[4] == 5

# sort 测试
let numbers = [3, 1, 4, 1, 5, 6]
let sorted_nums = sort(numbers)
assert sorted_nums[0] == 1
assert sorted_nums[1] == 1
assert sorted_nums[2] == 3
assert sorted_nums[3] == 4
assert sorted_nums[4] == 5
assert sorted_nums[5] == 6

# 列表连接测试
let lst_a = [1, 2, 3]
let lst_b = [4, 5, 6]
let combined = lst_a + lst_b
assert len(combined) == 6
assert combined[0] == 1
assert combined[5] == 6

print("列表操作测试通过")

## 9. 字典操作测试
print("\n=== 9. 字典操作 ===")

let dict = { "name": "Alice", "age": 30 }
assert dict["name"] == "Alice"
assert dict["age"] == 30

# 更新值
dict["age"] = 31
assert dict["age"] == 31

# 添加新键
dict["city"] = "Shanghai"
assert dict["city"] == "Shanghai"
assert len(dict) == 3

print("字典操作测试通过")

## 10. 错误处理测试
print("\n=== 10. 错误处理 ===")

let error_caught = false
let finally_executed = false

try {
    throw "Test error"
} catch err {
    error_caught = true
    assert err == "Test error"
} finally {
    finally_executed = true
}

assert error_caught
assert finally_executed

# assert 测试
let assert_passed = true
try {
    assert_eq(2 + 3, 5)
} catch e {
    assert_passed = false
}
assert assert_passed

print("错误处理测试通过")

## 11. 内置函数测试
print("\n=== 11. 内置函数 ===")

# 数学函数
assert abs(-5) == 5
assert abs(5) == 5

# 类型转换
assert int("42") == 42
assert float("3.14") == 3.14
assert str(123) == "123"
assert bool(1) == true
assert bool(0) == false

# 实用函数
let uuid_val = uuid()
assert type(uuid_val) == "str"
assert len(uuid_val) > 0

let time_val = time()
assert type(time_val) == "float"

print("内置函数测试通过")

