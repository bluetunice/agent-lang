# string_utils.afl - 可作为 skill 导入的工具函数

export function title_case(s) {
    let words = str(s).split(" ")
    let result = ""
    let i = 0
    for w in words {
        if i > 0 {
            result = result + " "
        }
        result = result + skill.text.upper(skill.text.substring(w, 0, 1)) + skill.text.substring(w, 1)
        i = i + 1
    }
    return result
}

export function count_words(s) {
    return len(str(s).split(" "))
}

export let VERSION = "1.0"
